{
  "expo": {
    "name": "BiteHub Vendor",
    "slug": "bitehub-vendor",
    "scheme": "bitehub-vendor",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "icon": "./assets/bitehub-icon.png",
    "splash": {
      "image": "./assets/bitehub-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#040000"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.bitehub.vendor",
      "buildNumber": "1.0.0",
      "supportsTablet": true
    },
    "android": {
      "package": "com.bitehub.vendor",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/bitehub-icon.png",
        "backgroundColor": "#040000"
      }
    },
    "extra": {
      "appVariant": "vendor"
    }
  }
}
